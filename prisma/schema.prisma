generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  cargo         String?
  accounts      Account[]
  sessions      Session[]
  tasks         Task[]         @relation("AssignedTasks")
  createdTasks  Task[]         @relation("CreatedTasks")
  comments      TaskComment[]
  passwordResetTokens PasswordResetToken[]
  tratativas         Tratativa[] @relation("TratativaResponsavel")
  createdTratativas  Tratativa[] @relation("TratativaCreatedBy")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  assigneeId  String?
  createdById String
  source      String    @default("manual")
  sourceRef   String?
  client      String?
  deliverTo   String?
  meetingTitle String? // assunto da reunião de origem (Meet Recap ou n8n), quando houver
  meetingDate  DateTime? // data da reunião de origem
  clientDraftCreatedAt DateTime? // quando o rascunho de cobrança pro cliente foi criado (evita duplicar)
  sortOrder   Float     @default(0)
  recurrence  String?   // "weekly" | "biweekly" | "monthly"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignee    User?          @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdBy   User           @relation("CreatedTasks", fields: [createdById], references: [id])
  comments    TaskComment[]
  subtasks    Subtask[]
  activities  TaskActivity[]
  links       TaskLink[]
  recapSuggestion RecapSuggestion?
  externalSuggestion ExternalSuggestion?

  @@index([assigneeId])
  @@index([status])
  @@index([client])
  @@index([updatedAt])
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  done      Boolean  @default(false)
  sortOrder Float    @default(0)
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  userName  String?
  type      String // "created" | "status" | "assignee" | "due_date" | "priority" | "title" | "recurrence"
  detail    String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskLink {
  id        String   @id @default(cuid())
  taskId    String
  url       String
  label     String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // "assigned" | "mention" | "comment" | "recap"
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

model ClientNote {
  id                String    @id @default(cuid())
  client            String    @unique
  notes             String?
  contacts          String?
  status            String    @default("ativo") // "ativo" | "pausado" | "encerrado"
  oxyStage          String    @default("nao_iniciado") // "nao_iniciado" | "em_validacao" | "em_implantacao" | "implantacao_interrompida" | "ativo"
  importType        String? // "manual" | "automatica" | "automatica_manual"
  lastDataUpdate    DateTime?
  oxyPendencies     String? // "o que" da pendência
  pendencyWho       String? // "quem" é responsável pela pendência
  erp               String? // nome do ERP usado pelo cliente
  accessMode        String? // modo de acesso ao ERP/Oxy
  updateFrequency   String? // frequência de atualização dos dados (ex: "toda quarta")
  updateResponsible String? // responsável por manter os dados atualizados
  routineWhat       String? // rotina recorrente com o cliente: o que é feito
  routineWho        String? // rotina recorrente: quem faz
  routineWhen       String? // rotina recorrente: quando
  healthStatus      String    @default("verde") // "verde" | "amarelo" | "vermelho" — semáforo de saúde da conta
  onboardingStartAt DateTime? // D+0: data do 1º pagamento, âncora dos marcos de onboarding
  cfoAllocatedAt    DateTime? // marco D+2
  kickoffScheduledAt DateTime? // marco D+3
  kickoffDoneAt     DateTime? // marco D+7
  setupDoneAt       DateTime? // marco D+30 (Setup + Comitê de Estruturação)
  diagnosticDoneAt  DateTime? // marco D+60 (Diagnóstico + Comitê de Diagnóstico) — mesma data da Etapa 4 (Apresentação final)
  oxyIntegratedAt   DateTime? // marco D+90 (Oxy + início do Comitê Estratégico Mensal)
  diagnosticoHandoffAt   DateTime? // Diagnóstico Etapa 0: handoff do Setup
  diagnosticoIntakeAt    DateTime? // Diagnóstico Etapa 1: intake complementar (assíncrono)
  diagnosticoIntakePendente String? // o que ainda falta pedir (Balanço, DFC, endividamento, Serasa, protestos, contrato social, dado de mercado...)
  diagnosticoAnaliseAt   DateTime? // Diagnóstico Etapa 2: análise e montagem (DRE, DFC, NCG/CDG/Tesouraria)
  diagnosticoValidacaoAt DateTime? // Diagnóstico Etapa 3: validação com o cliente (na semanal)
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([oxyStage])
  @@index([healthStatus])
}

model SetupMeeting {
  id            String    @id @default(cuid())
  client        String
  code          String // "R1" | "R2" | "R3" | "R4"
  scheduledAt   DateTime?
  completedAt   DateTime?
  participants  String?
  recordingUrl  String?
  transcriptUrl String?
  nextSteps     String?
  updatedAt     DateTime  @updatedAt

  @@unique([client, code])
  @@index([client])
}

model Tratativa {
  id                      String    @id @default(cuid())
  client                  String
  tipo                    String // "preventiva" | "reativa"
  motivo                  String
  descricao               String?
  satisfacao              String?
  problemaNaOxy           Boolean   @default(false)
  status                  String    @default("triagem") // "triagem" | "em_tratativa" | "plano_de_acao" | "concluida"
  responsavelId           String?
  dataPrevistaFinalizacao DateTime?
  planoDeAcao             String?
  desfecho                String? // "recuperado" | "churn" | "downsell" | "mudanca_escopo" | "desistencia"
  churnMotivo             String?
  churnData               DateTime?
  createdById             String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  responsavel User? @relation("TratativaResponsavel", fields: [responsavelId], references: [id])
  createdBy   User  @relation("TratativaCreatedBy", fields: [createdById], references: [id])

  @@index([client])
  @@index([status])
}

model MeetRecap {
  id             String    @id @default(cuid())
  subject        String
  body           String
  gmailId        String    @unique
  client         String?
  processedAt    DateTime?
  suggestedTasks String?
  suggestions    RecapSuggestion[]
  createdAt      DateTime  @default(now())

  @@index([processedAt])
}

model RecapSuggestion {
  id          String    @id @default(cuid())
  recapId     String
  index       Int // ordem de exibição dentro da leva de sugestões
  title       String // como a IA sugeriu originalmente (referência pra medir edição)
  description String?
  assignee    String?
  priority    String?
  dueDate     DateTime?
  status      String    @default("pending") // "pending" | "accepted" | "edited" | "rejected" | "superseded" | "duplicate"
  duplicateNote String? // preenchido quando status = "duplicate": explica com o que bateu
  taskId      String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recap MeetRecap @relation(fields: [recapId], references: [id], onDelete: Cascade)
  task  Task?     @relation(fields: [taskId], references: [id])

  @@index([recapId])
  @@index([status])
}

// Sugestão de tarefa vinda de uma fonte externa (ex.: workflow n8n).
// Igual à RecapSuggestion no espírito (fica pendente até alguém aceitar/descartar
// em /sugestoes-ia), mas sem depender de um MeetRecap.
model ExternalSuggestion {
  id          String    @id @default(cuid())
  source      String // "n8n" (aberto pra outras origens no futuro)
  sourceRef   String?
  title       String
  description String?
  client      String?
  priority    String?
  dueDate     DateTime?
  status      String    @default("pending") // "pending" | "accepted" | "edited" | "rejected" | "duplicate"
  duplicateNote String? // preenchido quando status = "duplicate": explica com o que bateu
  meetingTitle String? // assunto da reunião de origem, se o workflow mandar
  meetingDate  DateTime? // data da reunião de origem, se o workflow mandar
  taskId      String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task Task? @relation(fields: [taskId], references: [id])

  @@index([status])
  @@index([source])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model PlatformLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  category  String
  message   String
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([category])
  @@index([level])
}

model CalendarEvent {
  id           String   @id @default(cuid())
  googleId     String   @unique
  title        String
  client       String
  startAt      DateTime
  endAt        DateTime
  briefingSent Boolean  @default(false)
  meetingType  String? // "semanal" | "comite" | "kickoff" | "setup" | "interno" — extraído do título "| <Tipo>"
  temperature  String? // "otimo" | "bom" | "atencao" | "critico" — clima da reunião, preenchido depois
  nextSteps    String? // próximos passos validados pós-reunião
  attendanceConfirmed Boolean @default(false) // presença confirmada/corrigida
  registroConferido   Boolean @default(false) // registro (gravação/transcrição) conferido
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startAt])
  @@index([client])
}

model FechamentoMensal {
  id                    String   @id @default(cuid())
  client                String
  year                  Int
  month                 Int // 1-12
  comiteRealizado       Boolean  @default(false)
  rebalanceamentoFeito  Boolean  @default(false)
  conciliacaoOk         Boolean  @default(false)
  cpCrFechados          Boolean  @default(false)
  pendenciasAnotadas    String?
  maturidade            String? // avaliação livre da maturidade do fechamento
  healthReviewedAt      DateTime?
  updatedAt             DateTime @updatedAt

  @@unique([client, year, month])
  @@index([client])
}
